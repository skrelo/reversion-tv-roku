<?xml version="1.0" encoding="utf-8" ?>
<!-- Root scene. Owns the auth gate (token -> Home, no token -> Pairing) and a
     simple screen stack. TV_APP_SPEC §2, §3, §5. -->
<component name="MainScene" extends="Scene">
    <interface>
        <field id="launchArgs" type="assocarray" />
        <field id="exitApp" type="boolean" value="false" />
    </interface>

    <children>
        <Rectangle id="bg" width="1920" height="1080" color="0x0F1923FF" />
        <Group id="screenHost" />
    </children>

    <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Config.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Registry.brs" />
</component>
