<?xml version="1.0" encoding="utf-8" ?>
<!-- Home (TV_APP_SPEC §6). Left nav + hero (carousel/spotlight) + content
     rails + catalog mode + exit-confirmation overlay. All D-pad routing is
     explicit (HomeScreen owns focus; children render highlight from fields)
     per §12.

     Layout mirrors the Tizen app (Home.css): the hero docks at the top and its
     height animates 918<->648; the rails dock DIRECTLY below it (rails
     translation.y == hero height) and scroll internally. The hero is painted
     ON TOP of the rails and is opaque navy at its lower edge, so a rail scrolled
     up behind it is masked — no peeking dates between hero and rails. -->
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signedOut" type="boolean" value="false" />
        <field id="exitApp" type="boolean" value="false" />
        <!-- MainScene observes this to push Event Detail. Set to "" then to the
             event id so re-selecting the same event still fires onChange. -->
        <field id="openEventId" type="string" value="" />
        <!-- MainScene observes this to push the Player (hero Watch target / video
             card OK). Same set-"" then set-id trick to re-fire onChange. §9 -->
        <field id="openVideoId" type="string" value="" />
        <!-- MainScene observes this to push the Settings screen (left-nav gear). §10 -->
        <field id="openSettings" type="boolean" value="false" />
    </interface>

    <children>
        <Rectangle id="bg" width="1920" height="1080" color="0x0F1923FF" />

        <!-- Rails dock directly below the hero (y tracks the hero height). -->
        <Group id="railsContainer" translation="[150,918]">
            <Group id="railsContent" />
        </Group>

        <!-- Hero painted ON TOP of rails so scrolled-up rails hide behind it. -->
        <HeroView id="hero" />

        <!-- Left nav on top of content. -->
        <HomeNav id="nav" />

        <!-- Loading + error states. -->
        <Group id="loading" translation="[960,540]" visible="false">
            <Label id="loadingLabel" text="Loading…" translation="[-100,0]" width="200" horizAlign="center" color="0xF0EBE3FF">
                <Font role="font" uri="pkg:/fonts/Montserrat-Regular.ttf" size="28" />
            </Label>
        </Group>
        <Label id="errorLabel" translation="[200,500]" width="1520" horizAlign="center" wrap="true" visible="false" color="0xFF8A8AFF">
            <Font role="font" uri="pkg:/fonts/Montserrat-Regular.ttf" size="30" />
        </Label>
        <Group id="retryBtn" translation="[810,580]" visible="false">
            <Rectangle id="retryBg" width="300" height="60" color="0x1B2A3AFF" />
            <Label id="retryLabel" text="Try Again" translation="[0,0]" width="300" height="60" horizAlign="center" vertAlign="center" color="0xFFFFFFFF">
                <Font role="font" uri="pkg:/fonts/Montserrat-SemiBold.ttf" size="26" />
            </Label>
        </Group>
        <Label id="emptyLabel" translation="[200,500]" width="1520" horizAlign="center" visible="false" color="0x8C9EB0FF" text="Nothing here yet.">
            <Font role="font" uri="pkg:/fonts/Montserrat-Regular.ttf" size="30" />
        </Label>

        <!-- Transient toast for not-yet-built destinations. -->
        <Group id="toast" translation="[0,960]" visible="false">
            <Rectangle id="toastBg" width="560" height="70" translation="[680,0]" color="0x23324AF2">
                <Label id="toastLabel" width="560" height="70" horizAlign="center" vertAlign="center" color="0xFFFFFFFF">
                    <Font role="font" uri="pkg:/fonts/Montserrat-SemiBold.ttf" size="26" />
                </Label>
            </Rectangle>
        </Group>

        <!-- Exit-confirmation overlay (§6.7). -->
        <Group id="exitDialog" visible="false">
            <Rectangle id="exitScrim" width="1920" height="1080" color="0x0A0F16E6" />
            <Rectangle id="exitCard" width="760" height="320" translation="[580,380]" color="0x1A2535FF">
                <Label id="exitTitle" width="680" translation="[40,48]" wrap="true" color="0xFFFFFFFF"
                       text="Exit The Reversion Archive?">
                    <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="38" />
                </Label>
                <Group id="exitCancel" translation="[40,200]">
                    <Poster id="exitCancelBg" width="320" height="72" uri="pkg:/images/btn_rounded.9.png" blendColor="0xC9A84CFF" />
                    <Label id="exitCancelLabel" width="320" height="72" horizAlign="center" vertAlign="center" text="Cancel" color="0x0F1923FF">
                        <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="28" />
                    </Label>
                </Group>
                <Group id="exitConfirm" translation="[400,200]">
                    <Poster id="exitConfirmBg" width="320" height="72" uri="pkg:/images/btn_rounded.9.png" blendColor="0x23324AFF" />
                    <Label id="exitConfirmLabel" width="320" height="72" horizAlign="center" vertAlign="center" text="Exit" color="0xFFFFFFFF">
                        <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="28" />
                    </Label>
                </Group>
            </Rectangle>
        </Group>

        <!-- Hero collapse/expand: hero height + rails dock-y animate together. -->
        <Animation id="heroAnim" duration="0.5" easeFunction="outCubic">
            <FloatFieldInterpolator id="heroHInterp" key="[0,1]" fieldToInterp="hero.heroHeight" />
            <Vector2DFieldInterpolator id="railsYInterp" key="[0,1]" fieldToInterp="railsContainer.translation" />
        </Animation>
        <!-- Vertical rail scroll. -->
        <Animation id="railScrollAnim" duration="0.3" easeFunction="outCubic">
            <Vector2DFieldInterpolator id="railScrollInterp" key="[0,1]" fieldToInterp="railsContent.translation" />
        </Animation>
    </children>

    <script type="text/brightscript" uri="pkg:/components/screens/HomeScreen.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Config.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Registry.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Api.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Models.brs" />
</component>
