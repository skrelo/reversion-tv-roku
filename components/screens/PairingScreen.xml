<?xml version="1.0" encoding="utf-8" ?>
<!-- Pairing / device-auth. TV_APP_SPEC §5. Layout/palette mirror the Tizen
     reference (src/screens/Pairing.css): solid navy bg, transparent brand
     lockup top-left, QR + info pair centered, gold code + bold gold URL. -->
<component name="PairingScreen" extends="Group">
    <interface>
        <field id="paired" type="boolean" value="false" />
        <field id="exitApp" type="boolean" value="false" />
    </interface>

    <children>
        <Rectangle id="bg" width="1920" height="1080" color="0x0F1923FF" />

        <!-- Transparent brand lockup (emblem + wordmark), top-left. -->
        <Poster id="brand" uri="pkg:/images/brand_lockup.png" translation="[96,64]"
                width="300" height="116" loadDisplayMode="scaleToFit" />

        <!-- QR card: white, 440x440, content inset 24 (§5: ~58% screen height). -->
        <Rectangle id="qrCard" width="440" height="440" color="0xFFFFFFFF" translation="[320,300]" />
        <QRCode id="qr" ecl="MEDIUM" border="2" pixel="16"
                width="392" height="392" loadDisplayMode="scaleToFit"
                translation="[344,324]" />
        <Label id="qrCaption" text="Or scan to pair" translation="[320,758]" width="440"
               horizAlign="center" color="0x8C9EB0FF">
            <Font role="font" uri="pkg:/fonts/Montserrat-Regular.ttf" size="24" />
        </Label>

        <!-- Info column, to the right of the QR. -->
        <Label id="title" text="Pair this TV" translation="[840,300]" width="760" color="0xFFFFFFFF">
            <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="46" />
        </Label>

        <Label id="step" text="On any browser, go to" translation="[840,384]" width="760" color="0xF0EBE3FF">
            <Font role="font" uri="pkg:/fonts/Montserrat-Regular.ttf" size="28" />
        </Label>
        <Label id="url" text="reversion.app/activate" translation="[840,424]" width="760" color="0xC9A84CFF">
            <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="34" />
        </Label>

        <Label id="codeCaption" text="YOUR CODE" translation="[840,516]" width="760" color="0x8C9EB0FF">
            <Font role="font" uri="pkg:/fonts/Montserrat-SemiBold.ttf" size="20" />
        </Label>
        <Label id="code" text="" translation="[840,548]" width="760" color="0xC9A84CFF">
            <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="72" />
        </Label>

        <Label id="countdown" text="" translation="[840,668]" width="760" color="0x8C9EB0AA">
            <Font role="font" uri="pkg:/fonts/Montserrat-Regular.ttf" size="22" />
        </Label>

        <!-- Exit confirmation dialog (same as HomeScreen §6.7). -->
        <Group id="exitDialog" visible="false">
            <Rectangle id="exitScrim" width="1920" height="1080" color="0x0A0F16E6" />
            <Rectangle id="exitCard" width="760" height="320" translation="[580,380]" color="0x1A2535FF">
                <Label id="exitTitle" width="680" translation="[40,48]" wrap="true" color="0xFFFFFFFF"
                       text="Exit The Reversion Archive?">
                    <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="38" />
                </Label>
                <Group id="exitCancel" translation="[40,200]">
                    <Poster id="exitCancelBg" width="320" height="72" uri="pkg:/images/btn_rounded.9.png" blendColor="0xC9A84CFF" />
                    <Label id="exitCancelLabel" width="320" height="72" horizAlign="center" vertAlign="center" text="Cancel" color="0x0F1923FF">
                        <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="28" />
                    </Label>
                </Group>
                <Group id="exitConfirm" translation="[400,200]">
                    <Poster id="exitConfirmBg" width="320" height="72" uri="pkg:/images/btn_rounded.9.png" blendColor="0x23324AFF" />
                    <Label id="exitConfirmLabel" width="320" height="72" horizAlign="center" vertAlign="center" text="Exit" color="0xFFFFFFFF">
                        <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="28" />
                    </Label>
                </Group>
            </Rectangle>
        </Group>

        <!-- Hard-error retry affordance (hidden unless a non-transient error). -->
        <Group id="errorGroup" translation="[840,720]" visible="false">
            <Label id="errorMsg" width="760" wrap="true" color="0xFF8A8AFF"
                   text="Something went wrong reaching the server.">
                <Font role="font" uri="pkg:/fonts/Montserrat-Regular.ttf" size="26" />
            </Label>
            <Button id="retryBtn" text="Retry" translation="[0,70]" minWidth="220" />
        </Group>
    </children>

    <script type="text/brightscript" uri="pkg:/components/screens/PairingScreen.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Config.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Registry.brs" />
    <script type="text/brightscript" uri="pkg:/components/lib/Api.brs" />
</component>
